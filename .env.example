# Soma — Environment Variables
# Copy to .env and fill in values

# Server
SOMA_PORT=55000

# Data directory (where soma.db lives)
SOMA_DATA_DIR=./data

# Root of the repo (for ink/ path resolution)
SOMA_REPO_ROOT=.

# Admin token — required, keep secret
SOMA_ADMIN_TOKEN=

# Optional: embedding provider URL (leave blank to use FTS-only mode)
# SOMA_EMBED_URL=https://api.openai.com/v1/embeddings
# SOMA_EMBED_MODEL=text-embedding-3-small

# Optional: encrypt document content at rest (AES-256-GCM)
# SOMA_ENCRYPTION_KEY=

# Optional: restrict which MCP tools are enabled/disabled (comma-separated)
# SOMA_ENABLED_TOOLS=
# SOMA_DISABLED_TOOLS=

# Optional: set to "stderr" when running MCP stdio inside Docker
# SOMA_LOG_TARGET=stderr

# OAuth (optional — for SSO login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# SOMA_SESSION_SECRET=
